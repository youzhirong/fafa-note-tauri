      CREATE TABLE IF NOT EXISTS notes (
        id TEXT PRIMARY KEY, title TEXT, content TEXT, format TEXT,
        folderId TEXT, tags TEXT, pinned INTEGER, createdAt INTEGER, updatedAt INTEGER
      );
      CREATE VIRTUAL TABLE IF NOT EXISTS notes_fts USING fts5(title, content, content='notes', content_rowid='rowid');
    `)
  }

  // ... 其余方法按 INoteRepository 实现，tags 用 JSON.stringify 存 TEXT ...
